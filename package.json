{
  "name": "football-quizball",
  "version": "1.0.0",
  "scripts": {
    "pool:seed": "cd backend && npm run pool:seed --",
    "blitz:seed": "cd backend && npm run blitz:seed --",
    "db:find-duplicate-answers": "cd backend && npm run db:find-duplicate-answers --",
    "blitz:dedupe-wrong-choices": "cd backend && npm run blitz:dedupe-wrong-choices --",
    "db:find-similar-questions": "cd backend && npm run db:find-similar-questions --",
    "db:cleanup-pools": "cd backend && npm run db:cleanup-pools --",
    "db:stats": "cd backend && npm run db:stats --",
    "db:translate-greek": "cd backend && npm run db:translate-greek --",
    "pool:migrate-difficulty": "cd backend && npm run pool:migrate-difficulty --",
    "pool:migrate-difficulty:apply": "cd backend && npm run pool:migrate-difficulty:apply",
    "pool:transfer-to-questions-v1": "cd backend && npm run pool:transfer-to-questions-v1 --",
    "backend": "cd backend && npm run start:dev",
    "frontend": "cd frontend && ng serve --port 4200",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "cd backend && npm install && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && ng build",
    "start:prod": "cd backend && npm run start:prod"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
