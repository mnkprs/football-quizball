{
  "name": "football-quizball-frontend",
  "version": "0.9.5.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "npx cap sync && sed -i '' \"s|pod 'CapacitorFirebaseAnalytics'|pod 'CapacitorFirebaseAnalytics/Analytics'|\" ios/App/Podfile && cd ios/App && pod install",
    "cap:build": "ng build --configuration production && npm run cap:sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "postinstall": "patch-package"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/service-worker": "^20.0.0",
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor-firebase/analytics": "^8.2.0",
    "@capacitor-firebase/app": "^8.2.0",
    "@capacitor-firebase/crashlytics": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^7.6.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/clipboard": "^7.0.2",
    "@capacitor/core": "^7.6.0",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.0",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^7.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@ngrx/signals": "^20.1.0",
    "@southdevs/capacitor-google-auth": "^7.0.0",
    "@supabase/supabase-js": "^2.98.0",
    "chart.js": "^4.5.1",
    "cordova-plugin-purchase": "^13.13.1",
    "firebase": "^12.12.0",
    "ng2-charts": "^6.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
