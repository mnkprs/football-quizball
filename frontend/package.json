    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.27",
    "jasmine-core": "~5.7.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "patch-package": "^8.0.1",
